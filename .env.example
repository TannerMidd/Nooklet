APP_URL=http://localhost:3000
DATABASE_URL=file:./data/recommendarr.db
# When running in Docker, the compose file overrides this to file:/app/data/recommendarr.db
# so the database lives on the mounted `recommendarr-data` volume.

# Required. Minimum 32 characters. Generate with: openssl rand -base64 48
AUTH_SECRET=replace-with-a-long-random-string

# Optional. Dedicated key for encrypting stored service-connection secrets. Falls
# back to AUTH_SECRET if unset. Minimum 32 characters when provided.
# SECRET_BOX_KEY=

# Optional. When true (default) the app may call private/RFC1918 hosts such as
# Sonarr/Radarr running on your LAN. Set to false in cloud deployments where
# user-supplied URLs should never resolve to the internal network.
# ALLOW_PRIVATE_SERVICE_HOSTS=true
